#!/usr/bin/env bash
# Pre-push hook: runs fast test suite and lint checks before allowing push.
# Bypass with: git push --no-verify

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
cd "$REPO_ROOT"

# Detect Python with pytest, preferring project venv over system installs.
PYTHON=""
# 1. Check for project venv
if [ -f ".venv/bin/python" ]; then
    if .venv/bin/python -c "import pytest" 2>/dev/null; then
        PYTHON=".venv/bin/python"
    fi
fi
# 2. Fall back to system Python
if [ -z "$PYTHON" ]; then
    for candidate in python3.14 python3.13 python3.12 python3 python; do
        if command -v "$candidate" >/dev/null 2>&1 && "$candidate" -c "import pytest" 2>/dev/null; then
            PYTHON="$candidate"
            break
        fi
    done
fi
if [ -z "$PYTHON" ]; then
    echo "WARNING: No python with pytest found, skipping tests"
    PYTHON="python3"
fi

FAILED=0

echo "=== Pre-push: running fast test suite ==="
"$PYTHON" -m pytest \
    tests/test_modules.py \
    tests/test_ctan.py \
    tests/test_properties.py \
    tests/test_build_py.py \
    tests/test_institutions.py \
    tests/test_config.py \
    tests/test_negative.py \
    tests/test_unicode.py \
    -v --timeout=60 -m "not slow" --tb=short -q || FAILED=1

echo "=== Pre-push: running lint checks ==="
# Use venv binaries when available for lint tools; fall back to PATH.
LINT_PYTHON="${PYTHON}"
if [ -f ".venv/bin/black" ]; then
    BLACK=".venv/bin/black"
    ISORT=".venv/bin/isort"
    FLAKE8=".venv/bin/flake8"
else
    BLACK="black"
    ISORT="isort"
    FLAKE8="flake8"
fi

"$BLACK" --check tests/*.py buildlib/*.py buildlib/**/*.py scripts/*.py tools/*.py build.py 2>/dev/null || FAILED=1
"$ISORT" --check --profile black tests/*.py buildlib/*.py buildlib/**/*.py scripts/*.py tools/*.py build.py 2>/dev/null || FAILED=1
"$FLAKE8" tests/*.py buildlib/*.py buildlib/**/*.py scripts/*.py tools/*.py build.py --max-line-length=100 --extend-ignore=E203,W503 2>/dev/null || FAILED=1

echo "=== Pre-push: validating Docker digest consistency ==="
"$PYTHON" scripts/validate-digest-consistency.py 2>/dev/null || FAILED=1

echo "=== Pre-push: validating semantic versioning ==="
"$PYTHON" scripts/check_semver.py 2>/dev/null || FAILED=1

if [ "$FAILED" -ne 0 ]; then
    echo "=== Pre-push: FAILED - push blocked ==="
    exit 1
fi

echo "=== Pre-push: ALL CHECKS PASSED ==="
