{
  "Place on top of main.tex, before \\begin{document}": {
    "prefix": "omnilatex-class",
    "body": [
      "\\documentclass[",
      "    language=english,",
      "    doctype=${1:article|thesis|book|report|letter},",
      "    institution=${2|none},",
      "]{../../omnilatex}"
    ],
    "description": "OmniLaTeX document class"
  }
}
