{
  "OmniLaTeX Document": {
    "prefix": "omnilatex",
    "body": [
      "\\documentclass[",
      "  doctype=${1:thesis},",
      "  language=${2:english},",
      "  institution=${3:none}",
      "]{omnilatex}",
      "",
      "\\begin{document}",
      "  $0",
      "\\end{document}"
    ],
    "description": "OmniLaTeX document skeleton"
  },
  "OmniLaTeX Title Page": {
    "prefix": "omnilatex-title",
    "body": ["\\title{${1:Title}}", "\\author{${2:Author}}", "\\date{${3:\\today}}"],
    "description": "OmniLaTeX title metadata"
  },
  "OmniLaTeX Abstract": {
    "prefix": "omnilatex-abstract",
    "body": ["\\begin{abstract}", "  $0", "\\end{abstract}"],
    "description": "Abstract environment"
  },
  "OmniLaTeX Todo": {
    "prefix": "todo",
    "body": ["\\todo{${1:TODO}}"],
    "description": "Todo note"
  },
  "OmniLaTeX Censor": {
    "prefix": "censor",
    "body": ["\\censor{${1:redacted}}"],
    "description": "Censored text"
  },
  "OmniLaTeX Section": {
    "prefix": "section",
    "body": ["\\section{${1:Section Title}}", "$0"],
    "description": "Section heading"
  },
  "OmniLaTeX Subsection": {
    "prefix": "subsection",
    "body": ["\\subsection{${1:Subsection Title}}", "$0"],
    "description": "Subsection heading"
  },
  "OmniLaTeX Figure": {
    "prefix": "figure",
    "body": [
      "\\begin{figure}[htbp]",
      "  \\centering",
      "  \\includegraphics[width=0.8\\textwidth]{${1:figure}}",
      "  \\caption{${2:Caption}}",
      "  \\label{fig:${3:label}}",
      "\\end{figure}"
    ],
    "description": "Figure environment"
  },
  "OmniLaTeX Table": {
    "prefix": "table",
    "body": [
      "\\begin{table}[htbp]",
      "  \\centering",
      "  \\begin{tabular}{${1|l|c|r|}}",
      "    \\hline",
      "    ${2:Header} \\\\ \\hline",
      "    ${3:Data} \\\\ \\hline",
      "  \\end{tabular}",
      "  \\caption{${4:Caption}}",
      "  \\label{tab:${5:label}}",
      "\\end{table}"
    ],
    "description": "Table environment"
  },
  "OmniLaTeX Math Block": {
    "prefix": "math",
    "body": ["\\begin{equation}", "  $0", "\\end{equation}"],
    "description": "Equation environment"
  },
  "OmniLaTeX Code Listing": {
    "prefix": "code",
    "body": [
      "\\begin{listing}[htbp]",
      "  \\begin{minted}{${1:python}}",
      "    $0",
      "  \\end{minted}",
      "  \\caption{${2:Caption}}",
      "  \\label{lst:${3:label}}",
      "\\end{listing}"
    ],
    "description": "Code listing with minted"
  },
  "OmniLaTeX Bibliography": {
    "prefix": "bibliography",
    "body": ["\\printbibliography[heading=bibintoc]", "$0"],
    "description": "Print bibliography"
  },
  "OmniLaTeX Algorithm": {
    "prefix": "algorithm",
    "body": [
      "\\begin{algorithm}[htbp]",
      "  \\caption{${1:Algorithm Title}}",
      "  \\label{alg:${2:label}}",
      "  \\begin{algorithmic}[1]",
      "    \\Procedure{${3:ProcedureName}}{${4:arguments}}",
      "      \\State $0",
      "    \\EndProcedure",
      "  \\end{algorithmic}",
      "\\end{algorithm}"
    ],
    "description": "Algorithm environment with pseudocode"
  },
  "OmniLaTeX Theorem": {
    "prefix": "theorem",
    "body": [
      "\\begin{theorem}[${1:Optional Title}]",
      "  \\label{thm:${2:label}}",
      "  $0",
      "\\end{theorem}"
    ],
    "description": "Theorem environment"
  },
  "OmniLaTeX Proof": {
    "prefix": "proof",
    "body": [
      "\\begin{proof}[${1:Proof of}]",
      "  $0",
      "\\end{proof}"
    ],
    "description": "Proof environment"
  },
  "OmniLaTeX Definition": {
    "prefix": "definition",
    "body": [
      "\\begin{definition}[${1:Optional Title}]",
      "  \\label{def:${2:label}}",
      "  $0",
      "\\end{definition}"
    ],
    "description": "Definition environment"
  },
  "OmniLaTeX Glossary Entry": {
    "prefix": "glossary",
    "body": [
      "\\newglossaryentry{${1:label}}{",
      "  name=${2:Display Name},",
      "  description=${3:Description of the term}",
      "}"
    ],
    "description": "Glossary entry definition"
  },
  "OmniLaTeX doctype thesis": {
    "prefix": "doctype-thesis",
    "body": ["\\documentclass[doctype=thesis]{omnilatex}"],
    "description": "OmniLaTeX thesis document"
  },
