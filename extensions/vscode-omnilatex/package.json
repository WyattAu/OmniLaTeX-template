{
  "name": "vscode-omnilatex",
  "displayName": "OmniLaTeX",
  "description": "OmniLaTeX document class integration — doctype picker, institution switcher, build commands",
  "version": "0.1.0",
  "publisher": "wyattau",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages", "Other"],
  "keywords": ["latex", "omnilatex", "koma-script", "academic", "thesis"],
  "activationEvents": [
    "onLanguage:latex",
    "workspaceContains:omnilatex.cls"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "omnilatex.pickDoctype",
        "title": "OmniLaTeX: Change Document Type",
        "category": "OmniLaTeX"
      },
      {
        "command": "omnilatex.pickInstitution",
        "title": "OmniLaTeX: Change Institution",
        "category": "OmniLaTeX"
      },
      {
        "command": "omnilatex.pickLanguage",
        "title": "OmniLaTeX: Change Language",
        "category": "OmniLaTeX"
      },
      {
        "command": "omnilatex.buildExample",
        "title": "OmniLaTeX: Build Current Document",
        "category": "OmniLaTeX"
      },
      {
        "command": "omnilatex.buildAll",
        "title": "OmniLaTeX: Build All Examples",
        "category": "OmniLaTeX"
      },
      {
        "command": "omnilatex.doctor",
        "title": "OmniLaTeX: Run Diagnostics",
        "category": "OmniLaTeX"
      },
      {
        "command": "omnilatex.createProject",
        "title": "OmniLaTeX: Create New Project",
        "category": "OmniLaTeX"
      }
    ],
    "snippets": [
      {
        "language": "latex",
        "path": "./snippets/omnilatex.json"
      }
    ],
    "configuration": {
      "title": "OmniLaTeX",
      "properties": {
        "omnilatex.defaultDoctype": {
          "type": "string",
          "default": "thesis",
          "enum": ["thesis", "dissertation", "article", "journal", "cv", "presentation", "poster", "letter", "book", "manual", "technicalreport", "standard", "patent", "cover-letter", "dictionary", "inlinepaper"],
          "description": "Default document type for new OmniLaTeX projects"
        },
        "omnilatex.defaultLanguage": {
          "type": "string",
          "default": "english",
          "description": "Default language for new OmniLaTeX projects"
        },
        "omnilatex.autoDetect": {
          "type": "boolean",
          "default": true,
          "description": "Auto-detect OmniLaTeX projects by looking for omnilatex.cls"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/WyattAu/OmniLaTeX-template.git",
    "directory": "extensions/vscode-omnilatex"
  },
  "bugs": {
    "url": "https://github.com/WyattAu/OmniLaTeX-template/issues"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
