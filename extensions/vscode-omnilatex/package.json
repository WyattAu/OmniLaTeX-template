{
  "name": "omnilatex",
  "displayName": "OmniLaTeX",
  "description": "OmniLaTeX document class support — doctype picker, institution switcher, and build commands",
  "version": "0.1.0",
  "publisher": "WyattAu",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "latex",
    "document class",
    "omnilatex",
    "koma-script",
    "lua"
  ],
  "activationEvents": [
    "onLanguage:latex",
    "onLanguage:latex-expl3",
    "onCommand:omnilatex.switchDoctype",
    "onCommand:omnilatex.switchInstitution",
    "onCommand:omnilatex.switchLanguage",
    "onCommand:omnilatex.build",
    "onCommand:omnilatex.buildAll"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "contributes": {
    "commands": [
      {
        "command": "omnilatex.switchDoctype",
        "title": "OmniLaTeX: Switch Document Type",
        "category": "OmniLaTeX"
      },
      {
        "command": "omnilatex.switchInstitution",
        "title": "OmniLaTeX: Switch Institution",
        "category": "OmniLaTeX"
      },
      {
        "command": "omnilatex.build",
        "title": "OmniLaTeX: Build Example",
        "category": "OmniLaTeX"
      },
      {
        "command": "omnilatex.buildAll",
        "title": "OmniLaTeX: Build All Examples",
        "category": "OmniLaTeX"
      }
    ],
    "keybindings": [
      {
        "command": "omnilatex.switchDoctype",
        "key": "ctrl+alt+d",
        "when": "editorTextFocus && (resourceLangId == latex || resourceLangId == latex-expl3)"
      },
      {
        "command": "omnilatex.switchInstitution",
        "key": "ctrl+alt+i",
        "when": "editorTextFocus && (resourceLangId == latex || resourceLangId == latex-expl3)"
      },
      {
        "command": "omnilatex.build",
        "key": "ctrl+alt+b",
        "when": "editorTextFocus && (resourceLangId == latex || resourceLangId == latex-expl3)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "omnilatex.switchDoctype",
          "when": "resourceLangId == latex || resourceLangId == latex-expl3",
          "group": "1_modification"
        },
        {
          "command": "omnilatex.switchInstitution",
          "when": "resourceLangId == latex || resourceLangId == latex-expl3",
          "group": "1_modification"
        }
      ]
    },
    "snippets": [
      {
        "language": "latex",
        "path": "./snippets/latex.json"
      },
      {
        "language": "latex",
        "path": "./snippets/omnilatex.json"
      }
    ],
    "configuration": {
      "title": "OmniLaTeX",
      "properties": {
        "omnilatex.statusBar.show": {
          "type": "boolean",
          "default": true,
          "description": "Show the OmniLaTeX status bar item"
        }
      }
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.118.0",
    "typescript": "^6.0.3"
  }
}
