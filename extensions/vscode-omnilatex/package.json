{
  "name": "omnilatex",
  "displayName": "OmniLaTeX",
  "description": "VS Code support for the OmniLaTeX document class — doctype picker, institution switcher, LuaLaTeX build commands, IntelliSense completion for \\documentclass options, LaTeX log diagnostics, and configurable build-on-save via latexmk.",
  "version": "2.1.0",
  "publisher": "wyattau",
  "license": "Apache-2.0",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#0A0E13"
  },
  "homepage": "https://wyattau.github.io/OmniLaTeX-template/",
  "repository": {
    "type": "git",
    "url": "https://github.com/WyattAu/OmniLaTeX-template"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Other"
  ],
  "keywords": [
    "latex",
    "luatex",
    "lualatex",
    "omnilatex",
    "thesis",
    "academic"
  ],
  "activationEvents": [
    "onLanguage:latex",
    "onLanguage:latex-expl3",
    "onCommand:omnilatex.switchDoctype",
    "onCommand:omnilatex.switchInstitution",
    "onCommand:omnilatex.build",
    "onCommand:omnilatex.buildAll"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "contributes": {
    "languages": [
      {
        "id": "latex",
        "extensions": [
          ".tex"
        ],
        "aliases": [
          "LaTeX",
          "tex"
        ]
      }
    ],
    "commands": [
      {
        "command": "omnilatex.switchDoctype",
        "title": "OmniLaTeX: Switch Document Type",
        "category": "OmniLaTeX"
      },
      {
        "command": "omnilatex.switchInstitution",
        "title": "OmniLaTeX: Switch Institution",
        "category": "OmniLaTeX"
      },
      {
        "command": "omnilatex.build",
        "title": "OmniLaTeX: Build Example",
        "category": "OmniLaTeX"
      },
      {
        "command": "omnilatex.buildAll",
        "title": "OmniLaTeX: Build All Examples",
        "category": "OmniLaTeX"
      }
    ],
    "keybindings": [
      {
        "command": "omnilatex.build",
        "key": "ctrl+shift+b",
        "when": "editorTextFocus && (resourceLangId == latex || resourceLangId == latex-expl3)"
      },
      {
        "command": "omnilatex.switchDoctype",
        "key": "ctrl+shift+t",
        "when": "editorTextFocus && (resourceLangId == latex || resourceLangId == latex-expl3)"
      },
      {
        "command": "omnilatex.switchInstitution",
        "key": "ctrl+alt+i",
        "when": "editorTextFocus && (resourceLangId == latex || resourceLangId == latex-expl3)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "omnilatex.switchDoctype",
          "when": "resourceLangId == latex || resourceLangId == latex-expl3",
          "group": "1_modification"
        },
        {
          "command": "omnilatex.switchInstitution",
          "when": "resourceLangId == latex || resourceLangId == latex-expl3",
          "group": "1_modification"
        }
      ]
    },
    "snippets": [
      {
        "language": "latex",
        "path": "./snippets/latex.json"
      },
      {
        "language": "latex",
        "path": "./snippets/omnilatex.json"
      }
    ],
    "configuration": {
      "title": "OmniLaTeX",
      "properties": {
        "omnilatex.statusBar.show": {
          "type": "boolean",
          "default": true,
          "description": "Show the OmniLaTeX status bar item displaying current doctype and institution."
        },
        "omnilatex.buildOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically build the current .tex file on save using latexmk with LuaLaTeX."
        },
        "omnilatex.build.engine": {
          "type": "string",
          "default": "latexmk",
          "enum": [
            "latexmk",
            "lualatex"
          ],
          "description": "Build engine to use for compile commands.",
          "order": 2
        },
        "omnilatex.build.outputDirectory": {
          "type": "string",
          "default": "",
          "description": "Output directory for build artifacts. Leave empty to use the default LaTeX output location.",
          "order": 3
        },
        "omnilatex.completion.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable IntelliSense completion for OmniLaTeX \\documentclass options (doctype, institution, language, color-mode, link-style, code-style).",
          "order": 4
        },
        "omnilatex.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Parse LaTeX .log files for errors and warnings, and display them as VS Code diagnostics.",
          "order": 5
        }
      }
    }
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/vscode": "^1.120.0",
    "typescript": "^6.0.3"
  }
}
