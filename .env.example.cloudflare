# OmniLaTeX Cloudflare Deployment
# ==================================
# Copy this file to .env and fill in your values.
# .env is gitignored and will NOT be committed.
#
# Get your values from:
#   API Token:  https://dash.cloudflare.com/profile/api-tokens
#               Template: Edit Cloudflare Pages
#   Account ID: https://dash.cloudflare.com -> any domain -> right sidebar
#   Zone ID:    https://dash.cloudflare.com -> domain -> Overview -> API section

CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
