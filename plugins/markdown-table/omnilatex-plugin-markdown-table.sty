%% omnilatex-plugin-markdown-table.sty
%% Markdown-style table rendering for OmniLaTeX
%%
%% Provides:
%%   \begin{markdownTable}{<num-cols>}{<col-spec>}
%%     Header row \\ ...
%%     Data row   \\ ...
%%   \end{markdownTable}
%%
%% Usage:
%%   \useplugin{markdown-table}
%%   \begin{markdownTable}{3}{llr}
%%     Name & Description & Price \\
%%     Widget & A widget & 10 \\
%%     Gadget & A gadget & 20 \\
%%   \end{markdownTable}

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{omnilatex-plugin-markdown-table}[2026/06/06 v1.0.0 Markdown Table OmniLaTeX Plugin]

%% ── Plugin Identity ────────────────────────────────────
\newcommand{\omnilatex@plugin@name}{markdown-table}
\newcommand{\omnilatex@plugin@version}{1.0.0}

%% ── Internal state ─────────────────────────────────────
\newcounter{omnilatex@mt@colcount}
\newcommand{\omnilatex@mt@colspec}{}

%% ── markdownTable environment ──────────────────────────
%% Usage: \begin{markdownTable}{<num-cols>}{<col-spec>}
%%        ... rows separated by \\ ...
%%        \end{markdownTable}
\newenvironment{markdownTable}[2]{%
  \setcounter{omnilatex@mt@colcount}{#1}%
  \def\omnilatex@mt@colspec{#2}%
  \par\addvspace{\baselineskip}%
  \noindent
  \begin{tabular}{\omnilatex@mt@colspec}%
  \hline
}{%
  \hline
  \end{tabular}%
  \par\addvspace{\baselineskip}%
}

%% ── Hooks ──────────────────────────────────────────────
\ClassInfo{omnilatex}{Loaded markdown-table plugin v\omnilatex@plugin@version}

\endinput
