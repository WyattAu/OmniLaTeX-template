\typeout{=== TIKZ-ENGINEERING: Flow chart styles ===}
\begin{tikzpicture}
\node[startstop] (start) {Start};
\node[process, below=of start] (proc) {Process};
\node[decision, below=of proc] (dec) {Decision};
\node[io, below=of dec] (io) {I/O};
\draw[arrow] (start) -- (proc);
\draw[arrow] (proc) -- (dec);
\draw[arrow] (dec) -- (io);
\end{tikzpicture}

\typeout{=== TIKZ-ENGINEERING: Pipe styles ===}
\begin{tikzpicture}
\node[pump] (p1) {P};
\node[valve, right=1cm of p1] (v1) {V};
\node[pipe] at ($(p1)!0.5!(v1)$) {};
\draw[pipe] (p1) -- (v1);
\end{tikzpicture}

\typeout{=== TIKZ-ENGINEERING: Symmetry cross ===}
