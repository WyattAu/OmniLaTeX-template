  }%
}

% -- Style: ASA (American Sociological Association) --
% Author-year, similar to APA with sociology conventions
\newcommand{\citestyle@asa}{%
  \ExecuteBibliographyOptions{%
    sorting=nyt,
    maxbibnames=99,
    maxcitenames=3,
    mincitenames=1,
    uniquelist=false,
    giveninits=true,
  }%
}

% -- Style: Bluebook (Legal) --
% Footnote-based legal citation style
\newcommand{\citestyle@bluebook}{%
  \ExecuteBibliographyOptions{%
    sorting=nyt,
    maxbibnames=99,
    maxcitenames=1,
    mincitenames=1,
    uniquelist=false,
    ibidtracker=constrict,
  }%
}

\endinput
