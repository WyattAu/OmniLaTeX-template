\newcommand{\theme@rose@footernote}{white!50}

%% --- Monochrome (Light) ---
%% Pure black and white — no color whatsoever.

\newcommand{\theme@monochrome@bg}{white}
\newcommand{\theme@monochrome@fg}{black}
\newcommand{\theme@monochrome@heading}{black}
\newcommand{\theme@monochrome@body}{black!80}
\newcommand{\theme@monochrome@accent}{black!70}
\newcommand{\theme@monochrome@blockbg}{black!5}
\newcommand{\theme@monochrome@blockframe}{black!60}
\newcommand{\theme@monochrome@link}{black!70}
\newcommand{\theme@monochrome@rule}{black!30}
\newcommand{\theme@monochrome@codebg}{black!5}
\newcommand{\theme@monochrome@footernote}{black!50}

