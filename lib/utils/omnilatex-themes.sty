%% ── Internal: Load Palette ────────────────────────
%% \applytheme@{name} copies the palette's 11 slots into
%% omnilatex@* color names using \colorlet.

\newcommand{\applytheme@}[1]{%
    \colorlet{omnilatex@bg}{\csname theme@#1@bg\endcsname}%
    \colorlet{omnilatex@fg}{\csname theme@#1@fg\endcsname}%
    \colorlet{omnilatex@heading}{\csname theme@#1@heading\endcsname}%
    \colorlet{omnilatex@body}{\csname theme@#1@body\endcsname}%
    \colorlet{omnilatex@accent}{\csname theme@#1@accent\endcsname}%
    \colorlet{omnilatex@blockbg}{\csname theme@#1@blockbg\endcsname}%
    \colorlet{omnilatex@blockframe}{\csname theme@#1@blockframe\endcsname}%
    \colorlet{omnilatex@link}{\csname theme@#1@link\endcsname}%
    \colorlet{omnilatex@rule}{\csname theme@#1@rule\endcsname}%
    \colorlet{omnilatex@codebg}{\csname theme@#1@codebg\endcsname}%
    \colorlet{omnilatex@footernote}{\csname theme@#1@footernote\endcsname}%
}

%% ── Internal: Apply Colors to Document Elements ───
%% \applytheme@colors wires the omnilatex@* colors into
%% KOMA-Script elements, hyperref, and page background.
%%
%% Heading and block colors are injected via \addtokomafont
%% during initialization (below).  That mechanism uses
%% \color{omnilatex@*} which resolves dynamically via
%% \colorlet, so mid-document theme switches take effect
%% immediately without calling \setkomacolor (which is
%% preamble-only on TL2024 and removed on TL2025+).

\newcommand{\applytheme@colors}{%
    \pagecolor{omnilatex@bg}%
    \color{omnilatex@fg}%
    %% Block color macros: set directly instead of via \setkomacolor
    %% (KOMA removed it in TL2025+).  These are read by
    %% \omnilatex@get@block@fg/bg in the block \renewenvironment.
    \expandafter\gdef\csname omnilatex@clr@block title@fg\endcsname{white}%
    \expandafter\gdef\csname omnilatex@clr@block title@bg\endcsname{omnilatex@blockframe}%
    \expandafter\gdef\csname omnilatex@clr@block body@bg\endcsname{omnilatex@blockbg}%
    \expandafter\gdef\csname omnilatex@clr@block title alerted@fg\endcsname{white}%
    \expandafter\gdef\csname omnilatex@clr@block title alerted@bg\endcsname{red!70!black}%
    \expandafter\gdef\csname omnilatex@clr@block body alerted@bg\endcsname{red!5}%
    \expandafter\gdef\csname omnilatex@clr@block title example@fg\endcsname{white}%
    \expandafter\gdef\csname omnilatex@clr@block title example@bg\endcsname{green!50!black}%
    \expandafter\gdef\csname omnilatex@clr@block body example@bg\endcsname{green!5}%
    %% Links and page elements
    \hypersetup{%
        colorlinks=true,
        linkcolor=omnilatex@link,
        urlcolor=omnilatex@link,
        citecolor=omnilatex@accent,%
    }%
    \ifdarkmode
        \hypersetup{pdfpagelayout=SinglePage}%
    \fi
    \@ifundefined{color@universityprimary}{}{%
        \colorlet{omnilatex@accent}{universityprimary}%
        \colorlet{omnilatex@blockframe}{universityprimary}%
        \colorlet{omnilatex@link}{universityprimary}%
        \expandafter\gdef\csname omnilatex@clr@block title@bg\endcsname{omnilatex@blockframe}%
        \hypersetup{%
            linkcolor=omnilatex@link,
            urlcolor=omnilatex@link,
            citecolor=omnilatex@accent,%
        }%
    }%
}



%% ── Theme Application ─────────────────────────────
%% \omnilatexusetheme{name} applies a complete color theme.
%%
%% If the name contains "-dark" (e.g., "monochrome-dark"), dark mode
%% is enabled automatically and the suffix is stripped to find the
%% palette name.
%%
%% Themes that are inherently dark (midnight, forest, rose) do NOT
%% have a separate -dark variant; the base palette is already dark.
%% For these themes, \lightmode has no effect (they stay dark).
%% For default/monochrome/sepia, a -dark variant can be requested.
%%
%% \usetheme is also provided via \providecommand for KOMA documents
%% (does not overwrite beamer's \usetheme in beamer mode).

\newcommand{\omnilatexusetheme}[1]{%
    \def\@theme@base{#1}%
    %% Handle -dark suffix
    \IfSubStr{\@theme@base}{-dark}{%
        \StrBefore{\@theme@base}{-dark}[\@theme@base]%
    }{}%
    \edef\omnilatex@currenttheme{\@theme@base}%
    \applytheme@{\@theme@base}%
    %% Wire all colors into document elements
    \applytheme@colors
}
\providecommand{\usetheme}[1]{\omnilatexusetheme{#1}}

%% ── Dark/Light Mode Toggle ────────────────────────

\newcommand{\darkmode}{%
    \darkmodetrue
    \omnilatexusetheme{\omnilatex@currenttheme-dark}%
}

\newcommand{\lightmode}{%
    \darkmodefalse
    \omnilatexusetheme{\omnilatex@currenttheme}%
}

%% ── Custom Color Override ─────────────────────────
%% \setthemecolor{<slot>}{<color>} allows per-slot overrides.
%% Slot names match the omnilatex@* names (without the prefix):
%%   bg, fg, heading, body, accent, blockbg, blockframe,
%%   link, rule, codebg, footernote
%%
%% After overriding, all document elements are refreshed.

\newcommand{\setthemecolor}[2]{%
    \colorlet{omnilatex@#1}{#2}%
}

%% ── Convenience: Theme Query ──────────────────────
%% \ifthememode{dark}{<true>}{<false>} executes code depending
%% on whether dark mode is active.

\newcommand{\ifthememode}[3]{%
    \ifdarkmode #1\else #2\fi
}

%% ── Heading Color Injection ───────────────────────
%% Patch KOMA's section/chapter format commands to apply
%% theme heading color directly.  Because \color{} resolves
%% its argument at render time, \colorlet{omnilatex@heading}
%% mid-document changes immediately change heading colors.
%%
%% We use \addtokomafont for each heading level rather than
%% patching \sectionlinesformat (which breaks KOMA's internal
%% argument handling for subsections/subsubsections, causing
%% them to show "234" instead of proper numbers).
%%
%% \addtokomafont appends a \color command to KOMA's font
%% definitions, which resolves \omnilatex@heading dynamically
%% at render time via \colorlet — so mid-document theme
%% switches take effect immediately.

\AddToHook{begindocument/end}{%
    %% --- headings: add color to each level's font ---
    \addtokomafont{section}{\color{omnilatex@heading}}%
    \addtokomafont{subsection}{\color{omnilatex@heading}}%
    \addtokomafont{subsubsection}{\color{omnilatex@heading}}%
    \addtokomafont{paragraph}{\color{omnilatex@heading}}%
    \addtokomafont{subparagraph}{\color{omnilatex@heading}}%
    %% chapter/part only exist in scrbook/scrreprt (not scrartcl)
    \Ifstr{\@baseclass}{scrbook}{%
      \addtokomafont{chapter}{\color{omnilatex@heading}}%
      \addtokomafont{part}{\color{omnilatex@heading}}%
      \addtokomafont{partnumber}{\color{omnilatex@heading}}%
    }{%
      \Ifstr{\@baseclass}{scrreprt}{%
        \addtokomafont{chapter}{\color{omnilatex@heading}}%
        \addtokomafont{part}{\color{omnilatex@heading}}%
        \addtokomafont{partnumber}{\color{omnilatex@heading}}%
      }{}%
    }%
    %% --- page headers/footers ---
    \addtokomafont{pagehead}{\color{omnilatex@heading}}%
    \addtokomafont{pagefoot}{\color{omnilatex@heading}}%
    \addtokomafont{caption}{\color{omnilatex@fg}}%
    \addtokomafont{captionlabel}{\color{omnilatex@accent}}%
    %% --- footnotes ---
    \addtokomafont{footnote}{\color{omnilatex@footernote}}%
    \addtokomafont{footnotelabel}{\color{omnilatex@accent}}%
}

%% ── Initialize ────────────────────────────────────
%% Apply the theme requested via the package option (default).

\omnilatexusetheme{\omnilatex@theme}

\endinput
