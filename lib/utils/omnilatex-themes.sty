%% OmniLaTeX Color Theme System
%% Light/dark mode and color presets
%%
%% Usage: \usepackage{lib/utils/omnilatex-themes}
%%        \usetheme{midnight}    % Apply a theme
%%        \darkmode              % Switch to dark mode
%%        \lightmode             % Switch to light mode
%%
%% Themes:
%%   default     — White bg, dark text, blue accents (OmniLaTeX standard)
%%   midnight    — Dark navy/blue theme
%%   forest      — Dark green theme
%%   rose        — Dark pink/magenta theme
%%   monochrome  — Pure black/white, no color
%%   sepia       — Warm paper-like tones
%%
%% Themes respect institution primary/secondary colors when defined.

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{lib/utils/omnilatex-themes}[2026/04/24 v1.0.0 OmniLaTeX color theme system]

\RequirePackage{xcolor}
\RequirePackage{xstring}
\RequirePackage{kvoptions}

%% ── KOMA-Script Compatibility ──
%% KOMA 3.49+ (TL2025) removed \setkomacolor entirely.
%% KOMA 3.43 (TL2024) has it but it is preamble-only.
%% On TL2024, \providecommand does nothing (KOMA's real version is used).
%% On TL2025+, we provide a working shim that stores fg/bg colors and
%% patches \usekomafont to apply them, since KOMA no longer does.
%% Ensure block environments exist before the conditional block tries
%% to save/patch them (TL2025+ KOMA removed them along with \setkomacolor).
\provideenvironment{block}[1]{\par\textbf{#1}\par}{\par}%
\provideenvironment{alertblock}[1]{\par\textbf{#1}\par}{\par}%
\provideenvironment{exampleblock}[1]{\par\textbf{#1}\par}{\par}%
\@ifundefined{setkomacolor}{%
  %% \omnilatex@clr@helper{element}{key=value}
  %% Parses a single key=value pair using \StrBefore/\StrBehind (xstring).
  \newcommand{\omnilatex@clr@helper}[2]{%
    \StrBefore{#2}{=}{\omnilatex@clr@k}%
    \StrBehind{#2}{=}{\omnilatex@clr@v}%
    %% Trim leading space from value
    \IfBeginWith{\omnilatex@clr@v}{ }{%
      \StrGobbleLeft{\omnilatex@clr@v}{1}[\omnilatex@clr@v]%
    }{}%
    \ifdefstring{\omnilatex@clr@k}{fg}{%
      \expandafter\edef\csname omnilatex@clr@#1@fg\endcsname{\omnilatex@clr@v}%
    }{%
      \ifdefstring{\omnilatex@clr@k}{bg}{%
        \expandafter\edef\csname omnilatex@clr@#1@bg\endcsname{\omnilatex@clr@v}%
      }{}%
    }%
  }
  %% \omnilatex@setkomacolor@shim{element}{fg=color} or {bg=color, fg=color}
  %% Handles single pair (no comma) and two pairs (one comma).
  %% KOMA only ever uses fg, bg so we need at most 2 pairs.
  \newcommand{\omnilatex@setkomacolor@shim}[2]{%
    \IfSubStr{#2}{,}{%
      %% Two pairs: split on comma
      \StrBefore{#2}{,}{\omnilatex@clr@paira}%
      \StrBehind{#2}{,}{\omnilatex@clr@pairb}%
      \omnilatex@clr@helper{#1}{\omnilatex@clr@paira}%
      \omnilatex@clr@helper{#1}{\omnilatex@clr@pairb}%
    }{%
      %% Single pair
      \omnilatex@clr@helper{#1}{#2}%
    }%
  }
  \let\setkomacolor\omnilatex@setkomacolor@shim
  %% Patch \usekomafont to also apply stored fg color
  \let\omnilatex@orig@usekomafont\usekomafont
  \renewcommand{\usekomafont}[1]{%
    \omnilatex@orig@usekomafont{#1}%
    \@ifundefined{omnilatex@clr@#1@fg}{}{%
      \expandafter\color\expandafter{\csname omnilatex@clr@#1@fg\endcsname}%
    }%
  }
  %% Patch block environments to apply stored bg colors
  %% Only on TL2025+ where KOMA's \setkomacolor was removed
  \RequirePackage{tcolorbox}
  \tcbuselibrary{skins}
  \makeatletter
  \let\omnilatex@orig@block\block
  \let\omnilatex@orig@endblock\endblock
  \let\omnilatex@orig@alertblock\alertblock
  \let\omnilatex@orig@endalertblock\endalertblock
  \let\omnilatex@orig@exampleblock\exampleblock
  \let\omnilatex@orig@endexampleblock\endexampleblock
  \newcommand{\omnilatex@get@block@bg}[2]{%
    \@ifundefined{omnilatex@clr@#1@bg}{#2}{\csname omnilatex@clr@#1@bg\endcsname}%
  }
  \newcommand{\omnilatex@get@block@fg}[2]{%
    \@ifundefined{omnilatex@clr@#1@fg}{#2}{\csname omnilatex@clr@#1@fg\endcsname}%
  }
  \renewenvironment{block}[1]{%
    \tcolorbox[
      enhanced,
      colback=\omnilatex@get@block@bg{block body}{white},
      colframe=\omnilatex@get@block@bg{block title}{black},
      coltitle=\omnilatex@get@block@fg{block title}{white},
      fonttitle=\bfseries,
      title={#1},
      boxrule=0.4pt,
      arc=1pt,
      left=4pt, right=4pt, top=2pt, bottom=2pt,
      before skip=6pt,
      after skip=6pt,
    ]%
  }{%
    \endtcolorbox
  }
  \renewenvironment{alertblock}[1]{%
    \tcolorbox[
      enhanced,
      colback=\omnilatex@get@block@bg{block body alerted}{red!5},
      colframe=\omnilatex@get@block@bg{block title alerted}{red!70!black},
      coltitle=\omnilatex@get@block@fg{block title alerted}{white},
      fonttitle=\bfseries,
      title={#1},
      boxrule=0.4pt,
      arc=1pt,
      left=4pt, right=4pt, top=2pt, bottom=2pt,
      before skip=6pt,
      after skip=6pt,
    ]%
  }{%
    \endtcolorbox
  }
  \renewenvironment{exampleblock}[1]{%
    \tcolorbox[
      enhanced,
      colback=\omnilatex@get@block@bg{block body example}{green!5},
      colframe=\omnilatex@get@block@bg{block title example}{green!50!black},
      coltitle=\omnilatex@get@block@fg{block title example}{white},
      fonttitle=\bfseries,
      title={#1},
      boxrule=0.4pt,
      arc=1pt,
      left=4pt, right=4pt, top=2pt, bottom=2pt,
      before skip=6pt,
      after skip=6pt,
    ]%
  }{%
    \endtcolorbox
  }
  \makeatother
 }{}% end \@ifundefined{setkomacolor}

\makeatletter

%% ── Theme Option ──────────────────────────────────
%% Pass theme=NAME as a package option, e.g.:
%%   \usepackage[theme=midnight]{lib/utils/omnilatex-themes}

\def\omnilatex@theme{default}

%% ── State Tracking ────────────────────────────────
%% \ifdarkmode is true when the document is in dark mode.

\newif\ifdarkmode
\darkmodefalse

%% ── Current Theme Storage ─────────────────────────
%% Stores the base theme name (without -dark suffix) so that
%% \darkmode and \lightmode can toggle without remembering which
%% theme was originally selected.

\newcommand{\omnilatex@currenttheme}{default}

%% ── Color Palettes ────────────────────────────────
%% Each palette defines 11 semantic color slots:
%%   bg          — page background
%%   fg          — default text color
%%   heading     — section/chapter headings
%%   body        — running body text
%%   accent      — emphasis, highlights, footnote marks
%%   blockbg     — block environment body background
%%   blockframe  — block environment title bar / frame
%%   link        — hyperlink color
%%   rule        — horizontal rules, separators
%%   codebg      — inline/code listing background
%%   footernote  — footnotes, page headers/footers

%% --- Default (Light) ---
%% OmniLaTeX standard: clean white background, dark text, blue accents.

\newcommand{\theme@default@bg}{white}
\newcommand{\theme@default@fg}{black}
\newcommand{\theme@default@heading}{black}
\newcommand{\theme@default@body}{black!85}
\newcommand{\theme@default@accent}{blue!70!black}
\newcommand{\theme@default@blockbg}{black!5}
\newcommand{\theme@default@blockframe}{blue!60!black}
\newcommand{\theme@default@link}{blue!70!black}
\newcommand{\theme@default@rule}{black!30}
\newcommand{\theme@default@codebg}{black!5}
\newcommand{\theme@default@footernote}{black!60}

%% --- Midnight ---
%% Dark navy theme with cyan accents.

\newcommand{\theme@midnight@bg}{black!90!blue}
\newcommand{\theme@midnight@fg}{white!90}
\newcommand{\theme@midnight@heading}{blue!40!white}
\newcommand{\theme@midnight@body}{white!80}
\newcommand{\theme@midnight@accent}{cyan!60!white}
\newcommand{\theme@midnight@blockbg}{blue!20!black}
\newcommand{\theme@midnight@blockframe}{cyan!50!white}
\newcommand{\theme@midnight@link}{cyan!70!white}
\newcommand{\theme@midnight@rule}{white!20}
\newcommand{\theme@midnight@codebg}{black!80!blue}
\newcommand{\theme@midnight@footernote}{white!50}

%% --- Forest ---
%% Dark green theme with green accents.

\newcommand{\theme@forest@bg}{black!85!green}
\newcommand{\theme@forest@fg}{white!90}
\newcommand{\theme@forest@heading}{green!50!white}
\newcommand{\theme@forest@body}{white!80}
\newcommand{\theme@forest@accent}{green!60!white}
\newcommand{\theme@forest@blockbg}{green!15!black}
\newcommand{\theme@forest@blockframe}{green!50!white}
\newcommand{\theme@forest@link}{green!70!white}
\newcommand{\theme@forest@rule}{white!20}
\newcommand{\theme@forest@codebg}{black!80!green}
\newcommand{\theme@forest@footernote}{white!50}

%% --- Rose ---
%% Dark pink/magenta theme.

\newcommand{\theme@rose@bg}{black!85!red}
\newcommand{\theme@rose@fg}{white!90}
\newcommand{\theme@rose@heading}{red!40!white}
\newcommand{\theme@rose@body}{white!80}
\newcommand{\theme@rose@accent}{magenta!60!white}
\newcommand{\theme@rose@blockbg}{red!15!black}
\newcommand{\theme@rose@blockframe}{magenta!50!white}
\newcommand{\theme@rose@link}{magenta!70!white}
\newcommand{\theme@rose@rule}{white!20}
\newcommand{\theme@rose@codebg}{black!80!red}
\newcommand{\theme@rose@footernote}{white!50}

%% --- Monochrome (Light) ---
%% Pure black and white — no color whatsoever.

\newcommand{\theme@monochrome@bg}{white}
\newcommand{\theme@monochrome@fg}{black}
\newcommand{\theme@monochrome@heading}{black}
\newcommand{\theme@monochrome@body}{black!80}
\newcommand{\theme@monochrome@accent}{black!70}
\newcommand{\theme@monochrome@blockbg}{black!5}
\newcommand{\theme@monochrome@blockframe}{black!60}
\newcommand{\theme@monochrome@link}{black!70}
\newcommand{\theme@monochrome@rule}{black!30}
\newcommand{\theme@monochrome@codebg}{black!5}
\newcommand{\theme@monochrome@footernote}{black!50}

%% --- Monochrome (Dark) ---
\newcommand{\theme@monochrome@dark@bg}{black!90}
\newcommand{\theme@monochrome@dark@fg}{white!90}
\newcommand{\theme@monochrome@dark@heading}{white}
\newcommand{\theme@monochrome@dark@body}{white!75}
\newcommand{\theme@monochrome@dark@accent}{white!60}
\newcommand{\theme@monochrome@dark@blockbg}{white!10}
