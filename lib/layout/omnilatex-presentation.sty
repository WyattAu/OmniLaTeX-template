%% OmniLaTeX Presentation Module
%% Professional slide formatting for the presentation doctype
%%
%% Usage: Loaded automatically when doctype=presentation

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{lib/layout/omnilatex-presentation}[2026/04/24 v1.0.0 OmniLaTeX presentation module]

\RequirePackage{tcolorbox}
\RequirePackage{calc}
\RequirePackage{ifthen}

\tcbuselibrary{skins,breakable}

\makeatletter

%% ── Color Fallback ─────────────────────────────────
%% Ensure universityprimary is defined even without an institution config

\@ifundefined{color@universityprimary}{%
    \definecolor{universityprimary}{RGB}{0,63,114}%
    \definecolor{universitysecondary}{RGB}{0,113,188}%
}{}

%% ── TikZ Guard ─────────────────────────────────────
%% TikZ may not be loaded if enabletikz=false

\newif\ifpresentation@tikz
\@ifundefined{tikzpicture}{%
    \IfFileExists{tikz.sty}{%
        \RequirePackage{tikz}%
        \presentation@tikztrue
    }{%
        \presentation@tikzfalse
    }%
}{%
    \presentation@tikztrue
}

%% ── Navigation Symbols Toggle ──────────────────────
%% Default: off for clean slides

\newif\ifpresentation@navsymbols
\presentation@navsymbolsfalse

\newcommand{\presentationnavsymbolson}{\presentation@navsymbolstrue}
\newcommand{\presentationnavsymbolsoff}{\presentation@navsymbolsfalse}

%% ── Progress Bar Toggle ────────────────────────────

\newif\ifpresentation@progress
\presentation@progresstrue

\newcommand{\presentationprogresson}{\presentation@progresstrue}
\newcommand{\presentationprogressoff}{\presentation@progressfalse}

%% ── Frame Counter ──────────────────────────────────

\newcounter{framecounter}
\newcounter{totalframes}

\newcommand{\presentationframemark}{%
    \stepcounter{framecounter}%
}

\newcommand{\presentationcountframes}{%
    \setcounter{totalframes}{\value{framecounter}}%
    \setcounter{framecounter}{0}%
}

%% ── Frame Header ───────────────────────────────────

\newcommand{\presentationHeader}{%
    \ifpresentation@tikz
        \begin{tikzpicture}[remember picture, overlay]
            \fill[universityprimary]
                (current page.north west) rectangle
                ([yshift=-0.6cm]current page.north east);
            \node[anchor=west, white, font=\bfseries\normalsize]
                at ([xshift=0.8cm, yshift=-0.3cm]current page.north west)
                {\@title};
            \node[anchor=east, white, font=\small]
                at ([xshift=-0.8cm, yshift=-0.3cm]current page.north east)
                {\@author};
        \end{tikzpicture}%
    \fi
    \vspace{0.8cm}%
}

%% ── Frame Footer ───────────────────────────────────

\newcommand{\presentationFooter}{%
    \vfill
    \ifpresentation@tikz
        \begin{tikzpicture}[remember picture, overlay]
            \draw[universityprimary!60, line width=0.4pt]
                ([xshift=0.5cm, yshift=0.55cm]current page.south west) --
                ([xshift=-0.5cm, yshift=0.55cm]current page.south east);
            \node[anchor=west, font=\tiny, universityprimary]
                at ([xshift=0.5cm, yshift=0.3cm]current page.south west)
                {\@title};
            \node[anchor=east, font=\tiny, universityprimary]
                at ([xshift=-0.5cm, yshift=0.3cm]current page.south east)
                {\theframecounter\,/\,\thetotalframes};
        \end{tikzpicture}%
    \fi
}

%% ── Progress Bar ───────────────────────────────────

\newcommand{\presentationProgressBar}{%
    \ifpresentation@progress
        \ifpresentation@tikz
            \begin{tikzpicture}[remember picture, overlay]
                \fill[universityprimary!15]
                    (current page.south west) rectangle
                    ([yshift=2pt]current page.south east);
                \ifnum\value{totalframes}>0
                    \fill[universityprimary]
                        (current page.south west) rectangle
                        ([yshift=2pt,
                          xshift=\dimexpr\paperwidth*\ratio{\value{framecounter}\relax}{\value{totalframes}\relax}\relax]current page.south west);
                \fi
            \end{tikzpicture}%
        \fi
    \fi
}

%% ── Frame Environment ──────────────────────────────

\newenvironment{presentationframe}[1][]{%
    \clearpage
    \presentationframemark
    \presentationHeader
}{%
    \presentationFooter
    \presentationProgressBar
    \clearpage
}

%% ── Title Page ─────────────────────────────────────

\renewcommand{\maketitle}{%
    \clearpage
    \thispagestyle{empty}
    \ifpresentation@tikz
        \begin{tikzpicture}[remember picture, overlay]
            \fill[universityprimary]
                (current page.north west) rectangle
                ([yshift=-0.35\paperheight]current page.north east);
            \fill[universitysecondary]
                ([yshift=-0.35\paperheight]current page.north west) rectangle
                ([yshift=-0.37\paperheight]current page.north east);
            \node[anchor=center, white, font=\fontsize{28}{34}\selectfont\bfseries,
                  text width=0.8\paperwidth, align=center]
                at ([yshift=-0.18\paperheight]current page.north)
                {\@title};
            \node[anchor=center, white!90, font=\large,
                  text width=0.7\paperwidth, align=center]
                at ([yshift=-0.30\paperheight]current page.north)
                {\@author};
        \end{tikzpicture}%
    \fi
    \vspace{0.42\paperheight}
    \begin{center}
        {\large\color{universityprimary}\bfseries \@institute}\\[0.6em]
        {\normalsize\color{black!70}\@date}
    \end{center}
    \clearpage
}

%% ── Block Environments ─────────────────────────────

\newtcolorbox{presentationblock}[2][]{%
    enhanced,
    colback=white,
    colframe=universityprimary,
    fonttitle=\bfseries,
    title={#2},
    left=6pt, right=6pt, top=4pt, bottom=4pt,
    boxrule=0pt,
    borderline west={2.5pt}{0pt}{universityprimary},
    #1
}

\newtcolorbox{alertblock}[2][]{%
    enhanced,
    colback=red!5,
    colframe=red!70!black,
    fonttitle=\bfseries,
    title={#2},
    left=6pt, right=6pt, top=4pt, bottom=4pt,
    boxrule=0pt,
    borderline west={2.5pt}{0pt}{red!70!black},
    #1
}

\newtcolorbox{exampleblock}[2][]{%
    enhanced,
    colback=green!5,
    colframe=green!50!black,
    fonttitle=\bfseries,
    title={#2},
    left=6pt, right=6pt, top=4pt, bottom=4pt,
    boxrule=0pt,
    borderline west={2.5pt}{0pt}{green!50!black},
    #1
}

\newtcolorbox{noteblock}[2][]{%
    enhanced,
    colback=blue!5,
    colframe=blue!50!black,
    fonttitle=\bfseries,
    title={#2},
    left=6pt, right=6pt, top=4pt, bottom=4pt,
    boxrule=0pt,
    borderline west={2.5pt}{0pt}{blue!50!black},
    #1
}

\newtcolorbox{definitionblock}[2][]{%
    enhanced,
    colback=orange!5,
    colframe=orange!70!black,
    fonttitle=\bfseries,
    title={#2},
    left=6pt, right=6pt, top=4pt, bottom=4pt,
    boxrule=0pt,
    borderline west={2.5pt}{0pt}{orange!70!black},
    #1
}

%% ── Section Divider ────────────────────────────────

\newcommand{\presentationSection}[1]{%
    \clearpage
    \presentationframemark
    \ifpresentation@tikz
        \begin{tikzpicture}[remember picture, overlay]
            \fill[universityprimary]
                (current page.north west) rectangle
                ([yshift=-0.5\paperheight]current page.north east);
        \end{tikzpicture}%
    \fi
    \vfill
    \begin{center}
        {\fontsize{32}{38}\selectfont\bfseries\color{white}#1}
    \end{center}
    \vfill
    \presentationFooter
    \presentationProgressBar
    \clearpage
}

%% ── Two-Column Layout ──────────────────────────────

\newenvironment{presentationcolumns}[1][0.48]{%
    \begin{columns}[T]%
}{%
    \end{columns}%
}

\newcommand{\presentationcolumn}[1][0.48]{%
    \begin{column}{#1\textwidth}%
}

\newcommand{\endpresentationcolumn}{%
    \end{column}%
}

%% ── Slide Title Command ────────────────────────────
%% Keep backward compat with \slidetitle

\newcommand{\slidetitle}[1]{%
    \begin{center}
        {\LARGE\bfseries\color{universityprimary}#1}\par
        \vspace{1mm}
        {\color{universityprimary!40}\rule{0.6\textwidth}{0.8pt}}
    \end{center}
    \vspace{3mm}
}

%% ── Backward-Compatible slideframe ─────────────────
%% Wraps the old slideframe in the new frame system

\let\presentation@origslideframe\slideframe
\renewenvironment{slideframe}[1][]{%
    \presentationframe
}{%
    \endpresentationframe
}

\makeatother

\endinput
