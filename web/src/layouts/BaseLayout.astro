---
export interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Universal LaTeX document class with 27 doctypes, 21 institutions, 25 languages' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <meta name="theme-color" content="#0A0E13">
  <title>{title} | OmniLaTeX</title>
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`}>
  <link rel="stylesheet" href={`${base}styles/global.css`}>
</head>
<body>
  <nav class="nav">
    <div class="nav-inner">
      <a href={base} class="nav-brand">OmniLaTeX</a>
      <div class="nav-links">
        <a href={`${base}gallery`}>Gallery</a>
        <a href={`${base}docs`}>Docs</a>
        <a href={`${base}verify`}>Verify</a>
        <a href="https://github.com/WyattAu/OmniLaTeX-template" target="_blank" rel="noopener noreferrer">GitHub</a>
      </div>
    </div>
  </nav>

  <main>
    <slot />
  </main>

  <footer class="footer">
    <p>
      OmniLaTeX Template &mdash;
      <a href="https://github.com/WyattAu/OmniLaTeX-template" target="_blank" rel="noopener noreferrer">GitHub</a> &middot;
      <a href="https://github.com/WyattAu/OmniLaTeX-template/issues" target="_blank" rel="noopener noreferrer">Issues</a> &middot;
      <a href="https://ctan.org/pkg/omnilatex" target="_blank" rel="noopener noreferrer">CTAN</a>
    </p>
  </footer>
</body>
</html>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--bg-panel);
    border-bottom: 1px solid var(--border);
    backdrop-filter: blur(12px);
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-brand {
    font-weight: 700;
    font-size: 16px;
    color: var(--fg);
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .nav-links {
    display: flex;
    gap: 24px;
  }

  .nav-links a {
    color: var(--fg-muted);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    transition: color 0.15s;
  }

  .nav-links a:hover {
    color: var(--fg);
  }

  .footer {
    text-align: center;
    padding: 32px 24px;
    color: var(--fg-muted);
    font-size: 13px;
    border-top: 1px solid var(--border);
  }

  .footer a {
    color: var(--accent);
    text-decoration: none;
  }

  .footer a:hover {
    text-decoration: underline;
  }
</style>
