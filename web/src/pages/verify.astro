---
import BaseLayout from '../layouts/BaseLayout.astro';
import GitVerifier from '../components/GitVerifier';
---

<BaseLayout title="Build Verification" description="Verify OmniLaTeX PDF provenance against Git commit history.">
  <section class="page-header">
    <h1>Build Verification</h1>
    <p>Verify that a PDF was built from the latest commit. PDFs generated by OmniLaTeX embed a Git SHA via the <code>\GitVerificationBox</code> command.</p>
  </section>

  <GitVerifier client:load />
</BaseLayout>

<style>
  .page-header {
    padding: 48px 0 32px;
  }

  .page-header h1 {
    font-size: 2rem;
    margin-bottom: 8px;
  }

  .page-header p {
    color: var(--fg-muted);
    font-size: 16px;
    max-width: 700px;
    line-height: 1.7;
  }
</style>
