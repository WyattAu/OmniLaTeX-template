---
import BaseLayout from '../layouts/BaseLayout.astro';
import Validator from '../components/Validator';
---

<BaseLayout title="Build Verification" description="Validate your OmniLaTeX document configuration. Check doctype, institution, and language compatibility.">
  <section class="page-header">
    <h1>Build Verification</h1>
    <p>Validate your OmniLaTeX document configuration. Select a doctype, institution, and language to check compatibility.</p>
  </section>

  <Validator client:load />
</BaseLayout>

<style>
  .page-header {
    padding: 48px 0 32px;
  }

  .page-header h1 {
    font-size: 2rem;
    margin-bottom: 8px;
  }

  .page-header p {
    color: var(--fg-muted);
    font-size: 16px;
    max-width: 600px;
  }
</style>
