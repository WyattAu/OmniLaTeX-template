---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { slugToTitle, getBaseURL } from '../../lib/utils';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs.map(doc => ({
    params: { slug: doc.id.replace(/\.md$/, '') },
    props: { doc },
  }));
}

const { doc } = Astro.props;
const { Content, headings } = await render(doc);
const title = doc.data?.title || slugToTitle(doc.id);
const base = getBaseURL();

// Extract headings for table of contents (h2 and h3)
const toc = headings
  .filter(h => h.depth >= 2 && h.depth <= 3)
  .map(h => ({
    id: h.slug,
    text: h.text,
    depth: h.depth,
    children: [] as typeof toc,
  }));

// Build nested TOC: h3 items become children of the preceding h2
const nestedToc: typeof toc = [];
for (const item of toc) {
  if (item.depth === 2) {
    nestedToc.push({ ...item, children: [] });
  } else {
    const parent = nestedToc[nestedToc.length - 1];
    if (parent) parent.children.push(item);
  }
}
---

<BaseLayout title={title}>
  <div class="doc-layout">
    <nav class="doc-sidebar" aria-label="Documentation navigation">
      <a href={`${base}docs/`} class="back-link">&larr; All Docs</a>
      {nestedToc.length > 0 && (
        <ul class="toc" aria-label="Table of contents">
          {nestedToc.map(section => (
            <li>
              <a href={`#${section.id}`} class={section.depth === 2 ? 'toc-h2' : 'toc-h3'}>
                {section.text}
              </a>
              {section.children.length > 0 && (
                <ul>
                  {section.children.map(sub => (
                    <li key={sub.id}>
                      <a href={`#${sub.id}`} class="toc-h3">{sub.text}</a>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))}
        </ul>
      )}
    </nav>

    <article class="doc-content">
      <Content />
    </article>
  </div>
</BaseLayout>

<style>
  .doc-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 48px;
    padding: 48px 0 80px;
  }

  .doc-sidebar {
    position: sticky;
    top: 80px;
    align-self: start;
  }

  .back-link {
    display: inline-block;
    color: var(--fg-muted);
    font-size: 14px;
    text-decoration: none;
    margin-bottom: 24px;
  }

  .back-link:hover {
    color: var(--fg);
  }

  .toc {
    list-style: none;
    padding: 0;
    font-size: 13px;
    line-height: 1.5;
  }

  .toc li {
    margin-bottom: 2px;
  }

  .toc a {
    color: var(--fg-muted);
    text-decoration: none;
    display: block;
    padding: 2px 0;
    border-left: 2px solid transparent;
    padding-left: 12px;
    transition: color 0.15s, border-color 0.15s;
  }

  .toc a:hover {
    color: var(--fg);
  }

  .toc-h2 {
    font-weight: 600;
    border-left-color: var(--border-light);
    padding-left: 12px;
  }

  .toc-h3 {
    padding-left: 24px;
    font-size: 12px;
    border-left-color: transparent;
  }

  .toc-h3 a {
    padding-left: 24px;
  }

  .toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .doc-content {
    max-width: 760px;
    min-width: 0;
  }

  .doc-content :global(h1) {
    font-size: 2rem;
    margin-bottom: 24px;
  }

  .doc-content :global(h2) {
    font-size: 1.5rem;
    margin-top: 40px;
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }

  .doc-content :global(h3) {
    font-size: 1.2rem;
    margin-top: 32px;
    margin-bottom: 12px;
  }

  .doc-content :global(p) {
    margin-bottom: 16px;
    line-height: 1.7;
  }

  .doc-content :global(ul),
  .doc-content :global(ol) {
    margin-bottom: 16px;
    padding-left: 24px;
  }

  .doc-content :global(li) {
    margin-bottom: 4px;
    line-height: 1.6;
  }

  .doc-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 16px;
    font-size: 14px;
  }

  .doc-content :global(th),
  .doc-content :global(td) {
    padding: 8px 12px;
    border: 1px solid var(--border);
    text-align: left;
  }

  .doc-content :global(th) {
    background: var(--bg-panel);
    font-weight: 600;
  }

  .doc-content :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 16px;
    margin: 16px 0;
    color: var(--fg-muted);
  }

  .doc-content :global(pre) {
    background: var(--bg-panel);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 16px;
    overflow-x: auto;
    font-size: 13px;
    line-height: 1.6;
    margin-bottom: 16px;
  }

  .doc-content :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
  }

  .doc-content :global(pre code) {
    background: none;
    padding: 0;
  }

  @media (max-width: 768px) {
    .doc-layout {
      grid-template-columns: 1fr;
      gap: 24px;
      padding: 32px 0 48px;
    }

    .doc-sidebar {
      position: static;
      display: none;
    }
  }

  @media (min-width: 769px) and (max-width: 1200px) {
    .doc-layout {
      grid-template-columns: 180px 1fr;
      gap: 32px;
    }
  }
</style>
