---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const docs = await getCollection('docs');
const base = import.meta.env.BASE_URL;

// Group docs by category
const groups = {
  'Getting Started': docs.filter(d => ['USER_GUIDE', 'MIGRATION_GUIDE', 'FAQ', 'OVERLEAF'].some(n => d.id.includes(n))),
  'Reference': docs.filter(d => ['API_REFERENCE', 'INSTITUTION_GALLERY', 'editor-integration', 'gallery'].some(n => d.id.includes(n))),
  'Advanced': docs.filter(d => ['accessibility', 'PERFORMANCE', 'API_STABILITY', 'BREAKING_CHANGES', 'PLUGIN_CATALOG', 'LOCALIZATION_GUIDE'].some(n => d.id.includes(n))),
  'Distribution': docs.filter(d => ['CTAN_SUBMISSION', 'INSTITUTION_CONTRIBUTING', 'language-expansion'].some(n => d.id.includes(n))),
  'Manual': docs.filter(d => d.id.startsWith('manual/')),
};
---

<BaseLayout title="Documentation">
  <section class="page-header">
    <h1>Documentation</h1>
    <p>Everything you need to use, configure, and extend OmniLaTeX.</p>
  </section>

  <div class="doc-grid">
    {Object.entries(groups).map(([group, items]) => (
      <div class="doc-group">
        <h2>{group}</h2>
        <ul>
          {items.map(doc => {
            const title = doc.data?.title || doc.id.replace(/\.md$/, '').replace(/\//g, ' / ').replace(/-/g, ' ');
            return (
              <li>
                <a href={`${base}docs/${doc.id.replace(/\.md$/, '')}`}>{title}</a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </div>
</BaseLayout>

<style>
  .page-header {
    padding: 48px 0 32px;
  }

  .page-header h1 {
    font-size: 2rem;
    margin-bottom: 8px;
  }

  .page-header p {
    color: var(--fg-muted);
    font-size: 16px;
  }

  .doc-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 32px;
    padding-bottom: 80px;
  }

  .doc-group h2 {
    font-size: 16px;
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }

  .doc-group ul {
    list-style: none;
  }

  .doc-group li {
    margin-bottom: 8px;
  }

  .doc-group a {
    color: var(--fg);
    font-size: 14px;
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease);
  }

  .doc-group a:hover {
    color: var(--accent);
  }
</style>
