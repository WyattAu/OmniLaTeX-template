---
import BaseLayout from '../layouts/BaseLayout.astro';
import GalleryGrid from '../components/GalleryGrid';

const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';
---

<BaseLayout title="PDF Gallery">
  <section class="page-header">
    <h1>PDF Gallery</h1>
    <p>Browse example documents compiled with OmniLaTeX. Click any card to view the PDF.</p>
  </section>

  <GalleryGrid client:load />
</BaseLayout>

<style>
  .page-header {
    padding: 48px 0 32px;
  }

  .page-header h1 {
    font-size: 2rem;
    margin-bottom: 8px;
  }

  .page-header p {
    color: var(--fg-muted);
    font-size: 16px;
  }
</style>
