% --- Custom Colors ---
\definecolor{primary}{HTML}{2C3E50}
\definecolor{secondary}{HTML}{2980B9}
\definecolor{accent}{HTML}{E74C3C}
\definecolor{success}{HTML}{27AE60}
\definecolor{warning}{HTML}{F39C12}
\definecolor{lightgray}{HTML}{ECF0F1}
\definecolor{darkgray}{HTML}{7F8C8D}
\definecolor{codegreen}{HTML}{27AE60}
\definecolor{codeblue}{HTML}{2980B9}
\definecolor{codepurple}{HTML}{8E44AD}

% --- tcolorbox Styles ---
\newtcolor\boxed{definitionbox}[1][]{
    colback=secondary!5!white,
    colframe=secondary!75!black,
    fonttitle=\bfseries,
    title=Definition,
    #1
}

\newtcolor\boxed{theorembox}[1][]{
    colback=primary!5!white,
    colframe=primary!75!black,
    fonttitle=\bfseries,
    title=Theorem,
    #1
}

\newtcolor\boxed{examplebox}[1][]{
    colback=success!5!white,
    colframe=success!75!black,
    fonttitle=\bfseries,
    title=Example,
    #1
}

\newtcolor\boxed{remarkbox}[1][]{
    colback=warning!5!white,
    colframe=warning!75!black,
    fonttitle=\bfseries,
    title=Remark,
    #1
}

\newtcolor\boxed{algorithmbox}[1][]{
    colback=codepurple!5!white,
    colframe=codepurple!75!black,
    fonttitle=\bfseries,
    title=Algorithm,
    #1
}

% --- Custom TikZ Styles ---
\tikzset{
    block/.style={
        rectangle, draw, fill=secondary!20, text width=5em,
        text centered, rounded corners, minimum height=3em
    },
    decision/.style={
        diamond, draw, fill=accent!20, text width=4em,
        text centered, inner sep=0pt, aspect=2
    },
    line/.style={
        draw, -latex', thick
    },
    cloud/.style={
        draw, ellipse, fill=primary!10, minimum height=3em
    },
    every node/.style={font=\small},
    scalebox/.style={draw, fill=lightgray, rounded corners, inner sep=6pt},
}
