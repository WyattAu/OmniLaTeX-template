% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Apply Colors to Document Elements
% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Section headings use Michigan Blue
\addtokomafont{section}{\color{universityprimary}}
\addtokomafont{subsection}{\color{universityprimary}}

% Links and URLs use Michigan Blue
\hypersetup{linkcolor=universityprimary, urlcolor=universityprimary}

% Table rules use Maize
\arrayrulecolor{universitysecondary}

% Footer line uses Michigan Blue
\cfoot*{\color{universityprimary}\rule{\textwidth}{0.4pt}}

