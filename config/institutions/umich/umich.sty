% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Color Palette (Official Michigan Brand Guidelines)
% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Primary: Michigan Blue
\definecolor{universityprimary}{RGB}{0, 39, 76}
% Secondary: Maize
\definecolor{universitysecondary}{RGB}{255, 203, 5}
% Accent: Black
\definecolor{universityaccent}{RGB}{0, 0, 0}
% Neutral: White
\definecolor{universitywhite}{RGB}{255, 255, 255}

