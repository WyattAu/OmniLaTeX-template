\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{config/institutions/cornell/cornell}[2026-06-12 v1.0.0 Cornell Institution Configuration]

% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Color Palette (Official Cornell Brand Guidelines)
% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Primary: Cornell Red
\definecolor{universityprimary}{RGB}{179, 27, 27}
% Secondary: Black
\definecolor{universitysecondary}{RGB}{34, 34, 34}
% Accent: White
\definecolor{universityaccent}{RGB}{255, 255, 255}
% Neutral: White
\definecolor{universitywhite}{RGB}{255, 255, 255}

% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Logo
% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Place your Cornell logo in: assets/logos/cornell/logo.pdf
