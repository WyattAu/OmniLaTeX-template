\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{config/institutions/dartmouth/dartmouth}[2026-06-12 v1.0.0 Dartmouth Institution Configuration]

% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Color Palette (Official Dartmouth Brand Guidelines)
% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Primary: Dartmouth Green
\definecolor{universityprimary}{RGB}{0, 105, 62}
% Secondary: White
\definecolor{universitysecondary}{RGB}{255, 255, 255}
% Accent: Black
\definecolor{universityaccent}{RGB}{0, 0, 0}
% Neutral: White
\definecolor{universitywhite}{RGB}{255, 255, 255}

% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Logo
% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Place your Dartmouth logo in: assets/logos/dartmouth/logo.pdf
% Official logo download: https://dartmouth.edu/brand/
%
% \DeclareTranslation{english}{LogoInstitution}{%
%     \includegraphics[height=1.5cm]{assets/logos/dartmouth/logo}%
% }

% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Institution Name
% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\DeclareTranslation{english}{InstitutionName}{Dartmouth College}

% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Institution Link
% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\DeclareTranslation{english}{LogoInstitution}{%
    \includegraphics[height=1.5cm]{assets/logos/placeholder/logo}%
}
\DeclareTranslation{english}{LinkInstitution}{https://www.dartmouth.edu}

% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Apply Colors to Document Elements
% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Section headings use Dartmouth Green
\addtokomafont{section}{\color{universityprimary}}
\addtokomafont{subsection}{\color{universityprimary}}

% Links and URLs use Dartmouth Green
\hypersetup{linkcolor=universityprimary, urlcolor=universityprimary}

% Table rules use White
\arrayrulecolor{universitysecondary}

% Footer line uses Dartmouth Green
\cfoot*{\color{universityprimary}\rule{\textwidth}{0.4pt}}

\endinput
