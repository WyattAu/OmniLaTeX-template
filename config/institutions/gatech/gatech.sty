% Color Palette (Official Georgia Tech Brand Guidelines)
% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Primary: Tech Gold
\definecolor{universityprimary}{RGB}{179, 163, 105}
% Secondary: Navy
\definecolor{universitysecondary}{RGB}{0, 48, 87}
% Accent: White
\definecolor{universityaccent}{RGB}{255, 255, 255}
% Neutral: White
\definecolor{universitywhite}{RGB}{255, 255, 255}

