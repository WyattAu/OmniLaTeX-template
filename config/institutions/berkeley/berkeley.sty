% Color Palette (Official UC Berkeley Brand Guidelines)
% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Primary: Berkeley Blue
\definecolor{universityprimary}{RGB}{0, 50, 98}
% Secondary: California Gold
\definecolor{universitysecondary}{RGB}{253, 181, 21}
% Accent: Black
\definecolor{universityaccent}{RGB}{0, 0, 0}
% Neutral: White
\definecolor{universitywhite}{RGB}{255, 255, 255}

