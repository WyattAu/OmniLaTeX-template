\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{config/institutions/johnshopkins/johnshopkins}[2026-06-12 v1.0.0 Johns Hopkins Institution Configuration]

% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Color Palette (Official JHU Brand Guidelines)
% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Primary: Hopkins Blue
\definecolor{universityprimary}{RGB}{0, 45, 114}
% Secondary: Heritage Red
\definecolor{universitysecondary}{RGB}{207, 69, 32}
% Accent: Black
\definecolor{universityaccent}{RGB}{0, 0, 0}
% Neutral: White
\definecolor{universitywhite}{RGB}{255, 255, 255}

% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Logo
% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Place your Johns Hopkins logo in: assets/logos/johnshopkins/logo.pdf
% Official logo download: https://www.jhu.edu/about/brand-resources/
%
