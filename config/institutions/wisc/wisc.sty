% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Color Palette (Official Wisconsin Brand Guidelines)
% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Primary: Badger Red
\definecolor{universityprimary}{RGB}{197, 5, 12}
% Secondary: White
\definecolor{universitysecondary}{RGB}{255, 255, 255}
% Accent: Black
\definecolor{universityaccent}{RGB}{0, 0, 0}
% Neutral: White
\definecolor{universitywhite}{RGB}{255, 255, 255}

