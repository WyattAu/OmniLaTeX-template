\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{config/institutions/upenn/upenn}[2026-06-12 v1.0.0 UPenn Institution Configuration]

% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Color Palette (Official UPenn Brand Guidelines)
% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Primary: Penn Blue
\definecolor{universityprimary}{RGB}{1, 31, 91}
% Secondary: Gray
\definecolor{universitysecondary}{RGB}{153, 153, 153}
% Accent: White
\definecolor{universityaccent}{RGB}{255, 255, 255}
% Neutral: White
\definecolor{universitywhite}{RGB}{255, 255, 255}

% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Logo
% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Place your UPenn logo in: assets/logos/upenn/logo.pdf
% Official logo download: https://www.brand.upenn.edu/
%
% \DeclareTranslation{english}{LogoInstitution}{%
%     \includegraphics[height=1.5cm]{assets/logos/upenn/logo}%
% }

% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Institution Name
% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\DeclareTranslation{english}{InstitutionName}{University of Pennsylvania}

% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Institution Link
% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\DeclareTranslation{english}{LogoInstitution}{%
    \includegraphics[height=1.5cm]{assets/logos/placeholder/logo}%
}
\DeclareTranslation{english}{LinkInstitution}{https://www.upenn.edu}

% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Apply Colors to Document Elements
% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Section headings use Penn Blue
\addtokomafont{section}{\color{universityprimary}}
\addtokomafont{subsection}{\color{universityprimary}}

% Links and URLs use Penn Blue
\hypersetup{linkcolor=universityprimary, urlcolor=universityprimary}

% Table rules use Gray
\arrayrulecolor{universitysecondary}

% Footer line uses Penn Blue
\cfoot*{\color{universityprimary}\rule{\textwidth}{0.4pt}}

\endinput
