\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{config/institutions/caltech/caltech}[2026-06-12 v1.0.0 Caltech Institution Configuration]

% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Color Palette (Official Caltech Brand Guidelines)
% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Primary: Caltech Orange
\definecolor{universityprimary}{RGB}{255, 108, 12}
% Secondary: Black
\definecolor{universitysecondary}{RGB}{28, 28, 28}
% Accent: White
\definecolor{universityaccent}{RGB}{255, 255, 255}
% Neutral: White
\definecolor{universitywhite}{RGB}{255, 255, 255}

% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Logo
% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Place your Caltech logo in: assets/logos/caltech/logo.pdf
% Official logo download: https://www.caltech.edu/about/brand
%
% \DeclareTranslation{english}{LogoInstitution}{%
%     \includegraphics[height=1.5cm]{assets/logos/caltech/logo}%
% }

% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Institution Name
% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\DeclareTranslation{english}{InstitutionName}{California Institute of Technology}

% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Institution Link
% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\DeclareTranslation{english}{LogoInstitution}{%
    \includegraphics[height=1.5cm]{assets/logos/placeholder/logo}%
}
\DeclareTranslation{english}{LinkInstitution}{https://www.caltech.edu}

% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Apply Colors to Document Elements
% %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Section headings use Caltech Orange
\addtokomafont{section}{\color{universityprimary}}
\addtokomafont{subsection}{\color{universityprimary}}

% Links and URLs use Caltech Orange
\hypersetup{linkcolor=universityprimary, urlcolor=universityprimary}

% Table rules use Black
\arrayrulecolor{universitysecondary}

% Footer line uses Caltech Orange
\cfoot*{\color{universityprimary}\rule{\textwidth}{0.4pt}}

\endinput
