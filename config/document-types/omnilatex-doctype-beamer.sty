\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{config/document-types/omnilatex-doctype-beamer}[2026/06/06 v2.4.1 OmniLaTeX Beamer document type]

% Note: lib/graphics/omnilatex-beamer is already loaded by omnilatex.cls
% when doctype=beamer, so we skip the duplicate RequirePackage here.

\mode<presentation>

\setbeamersize{text margin left=8mm, text margin right=8mm}

\setbeamertemplate{navigation symbols}{}

\setbeamertemplate{footline}{%
  \hfill\insertframenumber/\inserttotalframenumber\hspace*{2mm}\vspace{2mm}%
}

\mode<all>

% Citations: beamer presentations typically do not need full biblatex.
% Users who need bibliography support in beamer can load omnilatex-biblio
% manually in their preamble.

\endinput
