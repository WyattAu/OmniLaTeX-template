\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{config/document-settings}[2025-10-27 OmniLaTeX document settings]

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Settings for the Titlepage, which are most of the time changed once for a document.
%
% They live in their own *.sty file aka package so they're out of the way.
% The settings here rarely need to be changed, but also don't fit into the *.cls aka
% documentclass file.
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%
% ── OmniLaTeX Override Quick Reference ──────────────────────────────────────────
%
% Fonts (call in preamble before \begin{document}):
%   \setMainFont{Font Name}              Override main serif font
%   \setSansFont{Font Name}              Override sans-serif font
%   \setMonoFont[Scale=MatchLowercase]{Font Name}  Override monospace font
%   \setMathFont{Font Name}              Override math font
%
% Page geometry:
%   \setCustomMargins{left}{right}{top}{bottom}  Override margins (e.g. 25mm)
%   \documentlayout{DIV=12,...}          KOMA typearea options (advanced)
%   \documentfontsize{12pt}              Font size
%
% Spacing and formatting:
%   \documentlinespacing{onehalf|double|1.2}   Line spacing
%   \documentparspacing{none|half|full}        Paragraph spacing
%   \documentitemspacing{none|compact|normal}  List item spacing
%   \documentfontmode{serif|sans|mono}         Default text font family
%
% Colors and themes:
%   \usetheme{midnight|forest|rose|sepia|monochrome|default}  Apply color theme
%   \setthemecolor{accent}{blue!60!black}      Override a theme color slot
%   \darkmode / \lightmode                     Toggle dark/light mode
%
% RTL languages (Arabic, Hebrew):
%   \setArabicFont{Font Name}          Override Arabic font
%   \setHebrewFont{Font Name}          Override Hebrew font
%
% ────────────────────────────────────────────────────────────────────────────────

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Document type
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\documenttype{Example Document}% Document type, like Master Thesis, PhD Thesis, ...

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Title
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\title{Template of the Institute of Engineering Thermodynamics (M-21)}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Author
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%%% If your using the template in german, please     %%%
%%% correct the gender to your preferred gender      %%%
%%% with one of the following commands:              %%%
% \RenewTranslation{german}{author}{Autor:in}%(default) or
% \RenewTranslation{german}{author}{Autorin}%or
% \RenewTranslation{german}{author}{Autor}%or
% Automatically set the correct article for the author in german
% depending on the set translation for author
\IfStrEqCase{\GetTranslationFor{german}{author}}{%
    % Case 1: author is Autor
    {Autor}{\RenewTranslation{german}{authorArticle}{der}}%
        % Case 2: author is Autorin
        {Autorin}{\RenewTranslation{german}{authorArticle}{die}}%
}%[Here goes the else case, if needed]
% Set the author
\author{Vasco Alexander Wild, Alex Povel}%

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Date
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% Print today's date w/ syntax of newer package datetime2:
\date{\DTMtoday{}}
%% Print a specified date in the right, language dependent format
% \date{\DTMdate{2023-01-15}}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Examiners
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
