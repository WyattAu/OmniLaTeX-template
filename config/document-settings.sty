\firstexamniner{Prof.~Dr.-Ing.~Arne Speerforck}
\secondexamniner{Prof.~Dr.-Ing.~Foo Bar}
\supervisor{John Doe, M.Sc.}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Enrolment/student ID number
