% PDF Metadata
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\hypersetup{%
    pdfsubject={%
            Comprehensive LaTeX template with examples for theses, books
            and more, employing the 'latest and greatest'.%
        },
    pdfkeywords={%
            latex,%
            template,%
            modern,%
            thesis,%
            phd,%
            master,%
            bachelor,%
            best practices,%
        },
    %% Default opening of the document in supported PDF viewers
    %% Possible inputs:
    %% SinglePage, OneColumn, TwoColumnLeft,
    %% TwoColumnRight, TwoPageLeft, and
    %% TwoPageRight or empty (just comment out)
    pdfpagelayout=TwoPageRight,
}%
